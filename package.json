{
  "name": "exoskull-v2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=@exoskull/web",
    "dev:desktop": "turbo dev --filter=@exoskull/desktop",
    "build:web": "turbo build --filter=@exoskull/web",
    "build:desktop": "turbo build --filter=@exoskull/desktop"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=20"
  }
}
