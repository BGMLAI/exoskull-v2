{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@exoskull/ui": [
        "../../packages/ui/src"
      ],
      "@exoskull/engine": [
        "../../packages/engine/src"
      ],
      "@exoskull/store": [
        "../../packages/store/src"
      ],
      "@exoskull/types": [
        "../../packages/types/src"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/*/src/**/*.ts",
    "../../packages/*/src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
